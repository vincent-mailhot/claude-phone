# ====================================
# Claude Phone — Alert Server Config
# ====================================
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and never committed.

# ====================================
# Network
# ====================================

# Your server's public or LAN IP (put into SDP so 3CX can route RTP audio back)
EXTERNAL_IP=YOUR_SERVER_IP

# ====================================
# Drachtio (SIP proxy)
# ====================================

DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=cymru

# Must match the --contact port in docker-compose.yml (default 5060)
DRACHTIO_SIP_PORT=5060

# ====================================
# FreeSWITCH (media server)
# ====================================

FREESWITCH_HOST=127.0.0.1
FREESWITCH_PORT=8021
FREESWITCH_SECRET=JambonzR0ck$

# ====================================
# 3CX / SIP
# ====================================

# 3CX cloud FQDN
SIP_DOMAIN=1590.3cx.cloud
SIP_REGISTRAR=1590.3cx.cloud
SIP_REGISTRAR_PORT=5060

# Extension that registers as the server identity
SIP_EXTENSION=14513
SIP_AUTH_ID=14513
SIP_PASSWORD=your-extension-password-here

# ====================================
# Alert target
# ====================================

# Extension the server will CALL when you POST to /api/alert
ALERT_TARGET_EXTENSION=14510

# ====================================
# Application
# ====================================

HTTP_PORT=3000
WS_PORT=3001
AUDIO_DIR=/app/audio

# ====================================
# Outbound call settings
# ====================================

OUTBOUND_RING_TIMEOUT=30

# ====================================
# espeak-ng TTS tuning (optional)
# ====================================

# ESPEAK_VOICE=en        # e.g. en, en-us, en-gb, fr, de
# ESPEAK_SPEED=140       # words per minute (80–450)
# ESPEAK_PITCH=50        # pitch 0–99
# ESPEAK_AMP=100         # amplitude 0–200

# ====================================
# Debug (optional)
# ====================================

# DEBUG=voice-app:*
